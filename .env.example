# App
APP_NAME="THSS RAG Chatbot"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Docker
# Override this when Docker Hub is slow or unavailable.
PYTHON_IMAGE=python:3.10-slim

# Demo authentication
DEMO_USERNAME=admin
DEMO_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-string
SESSION_TTL_SECONDS=28800
COOKIE_SECURE=false
CORS_ALLOW_ORIGINS=http://localhost:8000,https://localhost:8443

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30.0

# Data
DATABASE_PATH=data/rag.sqlite3
INDEX_DIR=data/index
SOURCE_BASE_URL=https://www.thss.tsinghua.edu.cn/

# Remote server
# Used for:
# - SSH deploy scripts (rsync + restart service)
# - Evaluation dataset fetch URL default (https://<SSH_HOST>:8443/questions.html)
SSH_HOST=xxx.xxx.xxx.xxx

# Deploy scripts (local -> remote)
SSH_USER=root
SSH_PORT=22
SSH_KEY_PATH=
REMOTE_DIR=/opt/apps/thss-rag/backend/current
REMOTE_VENV_DIR=
REMOTE_SERVICE_NAME=thss-rag
REMOTE_PIP_INSTALL=1
REMOTE_SYSTEMD_RESTART=1
RSYNC_DELETE=0

# Crawl & index scripts
CRAWL_FULL_SITE=1
CRAWL_LIMIT=850
CRAWL_RATE_LIMIT=0.75
BUILD_VECTOR_INDEX=0

# Server configure scripts
SERVICE_NAME=thss-rag
SERVICE_USER=root
INSTALL_SYSTEMD=1
WRITE_NGINX_SNIPPET=1
